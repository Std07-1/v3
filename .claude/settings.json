{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash(scp:* aione-vps:*)",
      "Bash(scp:* aione-vps:*)",
      "Bash(ssh aione-vps:*)",
      "Bash(ssh aione-vps:*)",
      "Bash(ssh -o BatchMode=yes aione-vps:*)",
      "Bash(ssh -o BatchMode=yes -o ConnectTimeout=* aione-vps:*)",
      "Bash(git push origin rebuild/*)",
      "Bash(git push origin feature/*)",
      "Bash(git push origin fix/*)",
      "Bash(git push origin deploy/*)",
      "Bash(git push -u origin *)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf $HOME)",
      "Bash(rm -rf $HOME/*)",
      "Bash(sudo rm -rf /)",
      "Bash(sudo rm -rf /*)",
      "Bash(sudo rm -rf /etc*)",
      "Bash(sudo rm -rf /usr*)",
      "Bash(sudo rm -rf /var*)",
      "Bash(sudo rm -rf /opt)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git filter-branch*)",
      "Bash(git update-ref -d*)",
      "Bash(dd if=*of=/dev/sd*)",
      "Bash(dd if=*of=/dev/nvme*)",
      "Bash(mkfs*)",
      "Bash(mkfs.ext4*)",
      "Bash(fdisk*)",
      "Bash(parted*)",
      "Bash(chmod -R 777 /)",
      "Bash(chmod -R 777 /*)",
      "Bash(chown -R * /)",
      "Bash(:(){ :|:& };:)",
      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "Bash(wget * | bash)",
      "Bash(shutdown -h now*)",
      "Bash(shutdown -P now*)",
      "Bash(halt -f*)",
      "Bash(poweroff -f*)",
      "Bash(ssh * rm -rf /*)",
      "Bash(ssh * sudo rm -rf /*)",
      "Bash(ssh * shutdown*)",
      "Bash(ssh * reboot*)"
    ]
  }
}