# Конфігурація перекладача. Скопіюй у .env та підлаштуй.

# Рушій: mock (тести) | nllb (прод, точний) | argos (легкий).
TRANSLATE_ENGINE=mock

# Кеш. Порожньо = in-memory; інакше Redis URL.
TRANSLATE_REDIS_URL=
# TRANSLATE_REDIS_URL=redis://redis:6379/0

# NLLB (для TRANSLATE_ENGINE=nllb).
TRANSLATE_NLLB_MODEL_DIR=models/nllb-200-distilled-600M-int8
TRANSLATE_NLLB_COMPUTE_TYPE=int8
TRANSLATE_NLLB_DEVICE=cpu

# Ліміт довжини запиту.
TRANSLATE_MAX_CHARS=5000
